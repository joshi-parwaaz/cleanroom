# ─── CleanRoom Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development          # development | production

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AWS (Optional — only needed for S3 audit log storage) ───────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=cleanroom-audit-logs

# ── NLP Model ───────────────────────────────────────────────────────────────────
# Path to ONNX-quantized BERT NER model (auto-downloaded by download_model.py)
MODEL_PATH=./models/bert_ner_quantized.onnx
TOKENIZER_PATH=./models/tokenizer
NER_CONFIDENCE_THRESHOLD=0.65

# ── File Size Limits (bytes) ─────────────────────────────────────────────────────
MAX_TXT_CSV_SIZE=10485760        # 10 MB
MAX_DOCX_SIZE=10485760           # 10 MB
MAX_PDF_TEXT_SIZE=26214400       # 25 MB
MAX_PDF_SCAN_SIZE=15728640       # 15 MB

# ── Temp Storage ─────────────────────────────────────────────────────────────────
TEMP_DIR=./tmp
FILE_TTL_HOURS=24

# ── Frontend (Vite) ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
